# ═══════════════════════════════════════════════════════════
# 三交易所整合网格机器人 · 配置文件
# 复制本文件为 .env 并填入对应值
# ═══════════════════════════════════════════════════════════

# 服务端口（默认 8080；Railway 会自动注入 PORT，无需手改）
PORT=8080

# 模拟账户初始余额 USDC（paper 模式共用）
PAPER_BALANCE=10000

# ── 云端部署（Railway / Docker）─────────────────────────────
# 仪表盘口令保护：一旦监听 0.0.0.0 或部署到 Railway，必须填。
# 强口令建议 20+ 字符，包含大小写数字符号。
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# 状态快照存放目录（Railway 上挂载 Volume 到 /data 并设 STATE_DIR=/data）
# 本地跑不用填，默认写在项目根目录
STATE_DIR=

# 绑定网卡：本地默认 127.0.0.1；Railway/Docker 自动切 0.0.0.0
HOST=

# ── 代理 / IP 配置 ────────────────────────────────────────
# 全局代理：同时应用于所有三个交易所（优先级最高）
# 留空则各交易所使用各自的独立代理配置
# 支持格式：
#   HTTP(S):  http://127.0.0.1:7890
#   SOCKS5:   socks5://127.0.0.1:1080
#   带认证:   socks5://user:pass@host:port
#   简写格式: host:port:user:pass
GLOBAL_PROXY=

# 各交易所独立代理（仅在 GLOBAL_PROXY 未设置时生效）
DECIBEL_PROXY=
EXTENDED_PROXY=
RISEX_PROXY=
ONDO_PROXY=
PERPL_PROXY=

# ── Decibel 交易所 ────────────────────────────────────────
# 运行模式：paper（模拟）| live（实盘）
DE_MODE=paper
# 网络：mainnet | testnet
DE_NETWORK=mainnet

# 实盘凭据（DE_MODE=live 时必填）
# API Key：在 geomi.dev 创建
DECIBEL_API_KEY=
# API 钱包 Ed25519 私钥：在 app.decibel.trade/api 创建
DECIBEL_PRIVATE_KEY=
# Trading Account 地址
DECIBEL_SUBACCOUNT=
# 自定义 API URL（留空使用默认）
DECIBEL_API_URL=

# ── Extended 交易所 ───────────────────────────────────────
EX_MODE=paper
EX_NETWORK=mainnet

# 实盘凭据（EX_MODE=live 时必填）
# 在 app.extended.exchange → API Management 获取
EXTENDED_API_KEY=
EXTENDED_VAULT=
EXTENDED_STARK_PRIVATE_KEY=
EXTENDED_STARK_PUBLIC_KEY=
EXTENDED_MAX_FEE=0.0005
EXTENDED_API_URL=

# ── RISEx 交易所 ──────────────────────────────────────────
RS_MODE=paper
RS_NETWORK=mainnet

# 实盘凭据（RS_MODE=live 时必填）
ACCOUNT_ADDRESS=
SIGNER_PRIVATE_KEY=
RISEX_API_URL=
RISEX_WS_URL=

# ── Ondo Perps 交易所（股票/黄金/原油 perps）──────────────
# 首版仅支持 paper 模式；live 模式已占位但尚未联调完成
ON_MODE=paper
ON_NETWORK=mainnet

# 实盘凭据（ON_MODE=live 时必填）
# app.ondoperps.xyz → Profile → API Keys → Add New，选权限后拿 KeyId + Secret
# Secret 只显示一次，务必当场保存
ONDO_API_KEY_ID=
ONDO_API_SECRET=
# builder code（可选，用于 Ondo 生态返佣分成，留空即可）
ONDO_BUILDER_CODE=
# 自定义 URL（留空用官方默认；sandbox 走 https://api.ondoperps-sandbox.xyz）
ONDO_API_URL=
ONDO_WS_URL=

# ── perpl.xyz 交易所（Monad L1 上的 perp DEX）──────────────
# 首版仅支持 paper 模式；live 走 WebSocket + Ed25519 签名，尚未联调完成
PL_MODE=paper
PL_NETWORK=mainnet

# 实盘凭据（PL_MODE=live 时必填）
# app.perpl.xyz/apikeys → 创建 API Key，得 API Key + Ed25519 私钥
PERPL_API_KEY=
PERPL_PRIVATE_KEY=
# 自定义 URL（留空用官方默认）
PERPL_API_URL=
PERPL_WS_URL=
PERPL_CHAIN_ID=

# ── AI 助手（可选：风控哨兵/日报/市况分析/对话操控/出区间建议）──
# 协议类型：openai | anthropic | gemini
#   openai = 所有 OpenAI 兼容服务（OpenAI/DeepSeek/Kimi/通义/智谱/OpenRouter/Ollama 等）
AI_PROVIDER=openai
AI_API_KEY=
# 接口地址（留空用官方默认）。示例：
#   DeepSeek: https://api.deepseek.com/v1    Kimi: https://api.moonshot.cn/v1
#   通义: https://dashscope.aliyuncs.com/compatible-mode/v1
#   Ollama 本地: http://127.0.0.1:11434/v1
AI_BASE_URL=
# 主模型（复盘/分析/对话）与小模型（哨兵巡检，高频省钱，可留空同主模型）
AI_MODEL=
AI_MODEL_SMALL=
# 哨兵巡检间隔（分钟，0=关闭）；BTC 市况报告间隔（分钟，0=关闭）；日报生成时间（0-23 整点）
AI_SENTINEL_MINUTES=5
AI_MARKET_MINUTES=30
AI_REPORT_HOUR=20

# 通知推送（可选，配了才会推）：Telegram 机器人 + 通用 Webhook（POST {"text":...}）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK=
