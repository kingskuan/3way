.state.json
.state.json.bak-*

# 依赖缓存
node_modules/

# 日志（可能含代理账号、出口 IP 等）
*.log
startup_log.txt
启动日志.txt

# ── 系统与编辑器 ────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
